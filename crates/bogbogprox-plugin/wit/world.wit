package bogbogprox:plugin@0.1.0;

interface types {
  /// A captured HTTP request handed to a plugin.
  record http-request {
    method: string,
    url: string,
    headers: list<tuple<string, string>>,
    body: list<u8>,
  }

  /// A captured HTTP response handed to a plugin.
  record http-response {
    status: u16,
    headers: list<tuple<string, string>>,
    body: list<u8>,
  }

  /// What a plugin decided for a request.
  variant req-action {
    /// Leave the request unchanged.
    unchanged,
    /// Forward this (edited) request.
    forward(http-request),
    /// Drop the request (client gets a synthetic 403).
    drop,
  }

  /// What a plugin decided for a response.
  variant resp-action {
    unchanged,
    forward(http-response),
    drop,
  }
}

/// Capabilities the host exposes to plugins (P1: logging only).
interface host {
  /// Log a message from the plugin. `level` = "info" | "warn" | "error".
  log: func(level: string, msg: string);
}

/// Hooks a plugin implements; the host calls these on each request/response.
interface hooks {
  use types.{http-request, http-response, req-action, resp-action};

  /// Human-readable plugin name (shown in the UI / logs).
  name: func() -> string;
  /// Called for each request, after built-in Match & Replace.
  on-request: func(req: http-request) -> req-action;
  /// Called for each response.
  on-response: func(resp: http-response) -> resp-action;
}

/// The plugin world.
world plugin {
  import host;
  export hooks;
}
